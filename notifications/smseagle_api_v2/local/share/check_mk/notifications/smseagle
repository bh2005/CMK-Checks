#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
Check_MK Notification Plugin for SMSEagle API v2

Sends notifications via SMSEagle device (SMS, TTS calls, or Wave files).
Supports failover to secondary SMSEagle device.

Install to: local/share/check_mk/notifications/smseagle_api_v2

Compatible with: CheckMK 2.4+
SMSEagle API: v2
"""

import sys
import os
import json
import ssl
import logging
from typing import Dict, Any, Optional, Tuple
from urllib.request import Request, urlopen
from urllib.error import HTTPError, URLError


def setup_logging() -> logging.Logger:
    """Configure logging for the notification plugin."""
    log_dir = os.path.join(os.environ.get("OMD_ROOT", "/tmp"), "var/log")
    log_file = os.path.join(log_dir, "smseagle_notifications.log")

    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s - %(levelname)s - %(message)s",
        handlers=[
            logging.FileHandler(log_file),
            logging.StreamHandler(sys.stdout),
        ],
    )
    return logging.getLogger(__name__)


logger = setup_logging()


def build_ssl_context(verify_ssl: bool) -> ssl.SSLContext:
    """
    Build an SSLContext that either verifies or ignores certificates.
    Using ssl.SSLContext is the correct approach since urllib.urlopen()
    has no 'verify' parameter like the requests library does.
    """
    ctx = ssl.create_default_context()
    if not verify_ssl:
        ctx.check_hostname = False
        ctx.verify_mode = ssl.CERT_NONE
        logger.warning("SSL certificate verification is DISABLED. Not recommended for production!")
    return ctx


def send_message(
    url: str,
    payload: Dict[str, Any],
    headers: Dict[str, str],
    verify_ssl: bool = True,
) -> Tuple[bool, Optional[Dict]]:
    """Send a single message to the SMSEagle API v2."""
    try:
        data = json.dumps(payload).encode("utf-8")
        req = Request(url, data=data, headers=headers, method="POST")

        logger.info("Sending request to %s", url)
        logger.debug("Payload: %s", payload)

        ctx = build_ssl_context(verify_ssl)
        with urlopen(req, timeout=30, context=ctx) as response:
            response_text = response.read().decode("utf-8")
            response_data = json.loads(response_text)
            logger.info("API Response: %s", response_data)

            # SMSEagle API v2 returns {"status": "queued", "id": <int>} on success
            if isinstance(response_data, dict) and response_data.get("status") == "queued":
                logger.info("Message queued successfully. ID: %s", response_data.get("id"))
                return True, response_data

            # Any other dict means an API-level error
            error_msg = response_data.get("message", "Unknown error") if isinstance(response_data, dict) else str(response_data)
            logger.error("API error: %s", error_msg)
            return False, response_data

    except HTTPError as e:
        try:
            error_body = json.loads(e.read().decode("utf-8"))
            logger.error("HTTP %s: %s", e.code, error_body.get("message", error_body))
        except Exception:
            logger.error("HTTP Error %s", e.code)
        return False, None
    except URLError as e:
        logger.error("URL Error: %s", e.reason)
        return False, None
    except json.JSONDecodeError as e:
        logger.error("Invalid JSON response: %s", e)
        return False, None
    except Exception as e:  # pylint: disable=broad-except
        logger.error("Unexpected error: %s", e)
        return False, None


def send_smseagle_notification(
    message_type: str,
    recipients: Dict[str, Any],
    text: Optional[str] = None,
    wave_id: Optional[int] = None,
    voice_id: int = 1,
    primary_url: str = "",
    primary_token: str = "",
    secondary_url: Optional[str] = None,
    secondary_token: Optional[str] = None,
    modem_no: int = 1,
    verify_ssl: bool = True,
) -> bool:
    """
    Send notification via SMSEagle with failover support.

    Args:
        message_type : 'sms', 'call_tts', or 'wave'
        recipients   : Dict with 'to' (list), 'contacts' (list of IDs), and/or 'groups' (list of IDs)
        text         : Message text — required for 'sms' and 'call_tts'
        wave_id      : Wave file ID stored on the SMSEagle — required for 'wave'
        voice_id     : TTS voice model ID (configurable, not hardcoded)
        primary_url  : Base URL of the primary SMSEagle device
        primary_token: API access token for the primary device
        secondary_url: Base URL of the failover SMSEagle device (optional)
        secondary_token: API access token for the failover device (optional)
        modem_no     : Modem slot to use (1–4, device dependent)
        verify_ssl   : Whether to verify SSL certificates
    """
    endpoints = {
        "sms": "/api/v2/messages/sms",
        "call_tts": "/api/v2/calls/tts_advanced",
        "wave": "/api/v2/calls/wave",
    }

    if message_type not in endpoints:
        logger.error("Invalid message type: %s (allowed: %s)", message_type, list(endpoints))
        return False

    endpoint = endpoints[message_type]

    # Build payload — spread recipients dict on top of modem selection
    payload: Dict[str, Any] = {"modem_no": modem_no, **recipients}

    if message_type == "sms":
        if not text:
            logger.error("message_type 'sms' requires a text value")
            return False
        payload["text"] = text

    elif message_type == "call_tts":
        if not text:
            logger.error("message_type 'call_tts' requires a text value")
            return False
        payload["text"] = text
        payload["voice_id"] = voice_id  # Configurable — was hardcoded to 3 before

    elif message_type == "wave":
        if not wave_id:
            logger.error("message_type 'wave' requires a wave_id value")
            return False
        payload["wave_id"] = wave_id

    def _try_send(base_url: str, token: str) -> bool:
        url = f"{base_url.rstrip('/')}{endpoint}"
        headers = {
            "Content-Type": "application/json",
            "access-token": token,   # SMSEagle API v2 uses this header (not Authorization: Bearer)
        }
        success, _ = send_message(url, payload, headers, verify_ssl)
        return success

    logger.info("Attempting to send '%s' via primary server...", message_type)
    if _try_send(primary_url, primary_token):
        return True

    if secondary_url and secondary_token:
        logger.info("Primary server failed — trying secondary server...")
        return _try_send(secondary_url, secondary_token)

    return False


def parse_recipients(pager: str) -> Dict[str, Any]:
    """
    Parse the CheckMK contact pager field into an SMSEagle-compatible recipients dict.

    Supported formats (semicolon-separated combinations):
        +491234567890          -> {"to": ["+491234567890"]}
        contacts:12,15         -> {"contacts": [12, 15]}
        groups:1,2             -> {"groups": [1, 2]}
        +491234;groups:1       -> {"to": ["+491234"], "groups": [1]}
    """
    recipients: Dict[str, Any] = {}

    for part in pager.split(";"):
        part = part.strip()
        if not part:
            continue

        if part.startswith("contacts:"):
            ids = [int(x.strip()) for x in part.replace("contacts:", "").split(",") if x.strip()]
            recipients["contacts"] = ids
        elif part.startswith("groups:"):
            ids = [int(x.strip()) for x in part.replace("groups:", "").split(",") if x.strip()]
            recipients["groups"] = ids
        elif part.startswith("+") or part.isdigit():
            recipients.setdefault("to", []).append(part)
        else:
            logger.warning("Ignoring unrecognised pager segment: '%s'", part)

    return recipients


def build_message(context: Dict[str, str], template: str) -> str:
    """Build the notification message from a template or using the default format."""
    if template:
        text = template
        for key, value in context.items():
            placeholder = f"${key.replace('NOTIFY_', '')}$"
            text = text.replace(placeholder, str(value))
        return text

    hostname = context.get("NOTIFY_HOSTNAME", "Unknown")
    what = context.get("NOTIFY_WHAT", "HOST")

    if what == "SERVICE":
        service = context.get("NOTIFY_SERVICEDESC", "Unknown Service")
        state = context.get("NOTIFY_SERVICESHORTSTATE", "UNKN")
        output = context.get("NOTIFY_SERVICEOUTPUT", "")
        text = f"[{state}] {hostname}/{service}: {output}"
    else:
        state = context.get("NOTIFY_HOSTSHORTSTATE", "UNKN")
        output = context.get("NOTIFY_HOSTOUTPUT", "")
        text = f"[{state}] Host {hostname}: {output}"

    # SMS messages are typically limited to 160 characters per segment
    if len(text) > 160:
        text = text[:157] + "..."

    return text


def main() -> None:
    """Main entry point — called by CheckMK when a notification is triggered."""
    context = {k: v for k, v in os.environ.items() if k.startswith("NOTIFY_")}

    logger.info("=" * 80)
    logger.info("SMSEagle Notification Plugin called")
    logger.info("Host   : %s", context.get("NOTIFY_HOSTNAME", "N/A"))
    logger.info("Service: %s", context.get("NOTIFY_SERVICEDESC", "Host Check"))
    logger.info(
        "State  : %s",
        context.get("NOTIFY_SERVICESHORTSTATE", context.get("NOTIFY_HOSTSHORTSTATE", "N/A")),
    )

    # -------------------------------------------------------------------------
    # Read parameters set by the WATO / Setup notification rule
    # The new Ruleset API (CMK 2.4) passes parameters as NOTIFY_PARAMETER_<KEY>
    # -------------------------------------------------------------------------
    message_type   = os.environ.get("NOTIFY_PARAMETER_MESSAGE_TYPE", "sms").lower()
    primary_url    = os.environ.get("NOTIFY_PARAMETER_PRIMARY_URL", "").strip()
    primary_token  = os.environ.get("NOTIFY_PARAMETER_PRIMARY_TOKEN", "").strip()
    secondary_url  = os.environ.get("NOTIFY_PARAMETER_SECONDARY_URL", "").strip() or None
    secondary_token = os.environ.get("NOTIFY_PARAMETER_SECONDARY_TOKEN", "").strip() or None
    modem_no       = int(os.environ.get("NOTIFY_PARAMETER_MODEM_NO", "1"))
    wave_id_raw    = os.environ.get("NOTIFY_PARAMETER_WAVE_ID", "").strip()
    voice_id       = int(os.environ.get("NOTIFY_PARAMETER_VOICE_ID", "1"))
    verify_ssl     = os.environ.get("NOTIFY_PARAMETER_VERIFY_SSL", "true").lower() == "true"
    message_template = os.environ.get("NOTIFY_PARAMETER_MESSAGE_TEMPLATE", "")

    # Validate required parameters
    if not primary_url or not primary_token:
        logger.error("Missing required parameters: PRIMARY_URL and/or PRIMARY_TOKEN")
        sys.exit(2)

    # Read recipient from the contact's pager address field
    pager = os.environ.get("NOTIFY_CONTACTPAGER", "").strip()
    if not pager:
        logger.error("No recipient found in NOTIFY_CONTACTPAGER")
        sys.exit(2)

    recipients = parse_recipients(pager)
    if not recipients:
        logger.error("Could not parse any recipients from pager field: '%s'", pager)
        sys.exit(2)

    text = build_message(context, message_template)

    logger.info("Message type : %s", message_type)
    logger.info("Recipients   : %s", recipients)
    logger.info("Message      : %.100s", text)

    try:
        success = send_smseagle_notification(
            message_type=message_type,
            recipients=recipients,
            text=text,
            wave_id=int(wave_id_raw) if wave_id_raw else None,
            voice_id=voice_id,
            primary_url=primary_url,
            primary_token=primary_token,
            secondary_url=secondary_url,
            secondary_token=secondary_token,
            modem_no=modem_no,
            verify_ssl=verify_ssl,
        )
    except Exception as e:  # pylint: disable=broad-except
        logger.error("Unexpected error: %s", e, exc_info=True)
        sys.exit(2)

    if success:
        logger.info("Notification sent successfully")
        sys.exit(0)
    else:
        logger.error("Failed to send notification via all configured servers")
        sys.exit(2)


if __name__ == "__main__":
    main()
